<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Custom Header Background (Rounded bottom) -->
    <View
        android:id="@+id/header_bg"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/bg_header_home"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Toolbar Content -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="@dimen/spacing_normal"
        android:paddingTop="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Logo & Title -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerCrop"
                android:scaleX="1.8"
                android:scaleY="1.8"
                android:src="@drawable/logo_nongki_bib" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_small"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:lineSpacingExtra="-4dp"
                    android:text="@string/nongki_bib"
                    android:textColor="@color/teal_dark"
                    android:textSize="@dimen/text_size_large"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Profile Avatars -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">


            <!-- Siti -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">
                <androidx.cardview.widget.CardView
                    android:layout_width="@dimen/avatar_size_small"
                    android:layout_height="@dimen/avatar_size_small"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/ic_profile"
                        android:scaleType="centerCrop" />
                </androidx.cardview.widget.CardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bib_label"
                    android:textColor="@color/teal_dark"
                    android:textSize="@dimen/text_size_small"
                    android:textStyle="bold"
                    android:background="@drawable/bg_label_white"
                    android:paddingHorizontal="6dp"
                    android:layout_marginTop="-4dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content Scroll -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="80dp">

            <!-- Productivity Card (Timer & Points) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_normal"
                android:layout_marginTop="@dimen/spacing_normal"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_normal"
                    android:background="@color/bg_light">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/points_label"
                                android:textColor="@color/text_grey"
                                android:textSize="@dimen/text_size_small" />
                            <TextView
                                android:id="@+id/tv_points"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1,250 PTS"
                                android:textColor="@color/accent"
                                android:textSize="@dimen/text_size_header"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_timer_action"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/start_nongki"
                            app:cornerRadius="20dp" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/timer_label"
                            android:textColor="@color/text_grey"
                            android:textSize="@dimen/text_size_small" />
                        <TextView
                            android:id="@+id/tv_countdown"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="02:00:00"
                            android:textColor="@color/primary"
                            android:textSize="36sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Warning Message -->
                    <LinearLayout
                        android:id="@+id/layout_warning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@color/warning_bg"
                        android:padding="@dimen/spacing_small"
                        android:layout_marginTop="@dimen/spacing_small"
                        android:visibility="visible">
                        <ImageView
                            android:layout_width="@dimen/spacing_large"
                            android:layout_height="@dimen/spacing_large"
                            android:src="@android:drawable/stat_sys_warning"
                            app:tint="@color/warning_orange" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_small"
                            android:text="@string/task_warning"
                            android:textColor="@color/warning_orange"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Welcome Banner -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_normal"
                android:layout_marginTop="@dimen/spacing_normal"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:background="@color/teal_dark"
                    android:padding="20dp">
                    <!-- Background abstract shapes could be images here -->
                    <TextView
                        android:id="@+id/tv_welcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/welcome_awardee"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_header"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tv_welcome"
                        android:layout_marginTop="4dp"
                        android:text="@string/welcome_subtitle"
                        android:textColor="@color/white_translucent"
                        android:textSize="13sp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Map Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_marginTop="12dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@android:drawable/ic_dialog_map"
                    app:tint="@color/grey_light" />

                <!-- Mock Pins -->
                <!-- Use custom layout for pins as seen in image -->
                <!-- JAKARTA center text -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Jakarta"
                    android:textColor="#444"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Float labels like in screenshot -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_map_pin_label"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:elevation="4dp"
                    android:layout_marginEnd="40dp"
                    android:layout_marginBottom="100dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_location_pin"
                        app:tint="@color/teal_accent"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/bib_spots"
                        android:textSize="@dimen/text_size_small"
                        android:textStyle="bold"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_map_pin_label"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="5dp"
                    android:elevation="4dp"
                    android:layout_marginEnd="@dimen/spacing_normal"
                    android:layout_marginBottom="40dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:gravity="center">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_profile"
                        app:tint="@color/teal_dark"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/teman_nongki"
                        android:textSize="@dimen/text_size_small"
                        android:textStyle="bold"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Bottom Sheet Style Content -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <View
                        android:layout_width="40dp"
                        android:layout_height="4dp"
                        android:background="@color/tab_inactive"
                        android:layout_gravity="center"
                        android:layout_marginBottom="@dimen/spacing_normal"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/recommendation_title"
                            android:textColor="@color/black"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="@string/see_more"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <!-- Horizontal Grid/List -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_normal"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Item 1 -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="140dp"
                                android:layout_height="180dp"
                                android:layout_marginEnd="12dp"
                                app:cardCornerRadius="16dp"
                                app:cardBackgroundColor="@color/teal_dark">
                                <RelativeLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="12dp">
                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="80dp"
                                        android:src="@drawable/ic_profile"
                                        android:scaleType="centerInside"
                                        app:tint="@color/teal_accent" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_alignParentBottom="true"
                                        android:text="@string/find_friends"
                                        android:textColor="@color/white"
                                        android:textSize="14sp"
                                        android:textStyle="bold" />
                                </RelativeLayout>
                            </androidx.cardview.widget.CardView>

                            <!-- Item 2 -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="140dp"
                                android:layout_height="180dp"
                                android:layout_marginEnd="12dp"
                                app:cardCornerRadius="16dp"
                                app:cardBackgroundColor="@color/brown_card">
                                <RelativeLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="12dp">
                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="80dp"
                                        android:src="@drawable/ic_acara"
                                        android:scaleType="centerInside"
                                        app:tint="@color/primary" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_alignParentBottom="true"
                                        android:text="@string/nearby_events"
                                        android:textColor="@color/white"
                                        android:textSize="14sp"
                                        android:textStyle="bold" />
                                </RelativeLayout>
                            </androidx.cardview.widget.CardView>

                            <!-- Item 3 -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="140dp"
                                android:layout_height="180dp"
                                android:layout_marginEnd="12dp"
                                app:cardCornerRadius="16dp"
                                app:cardBackgroundColor="@color/blue_card">
                                <RelativeLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="12dp">
                                    <ImageView
                                        android:layout_width="match_parent"
                                        android:layout_height="80dp"
                                        android:src="@drawable/ic_profile"
                                        android:scaleType="centerInside"
                                        app:tint="@color/orange_accent" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_alignParentBottom="true"
                                        android:text="@string/interest_groups"
                                        android:textColor="@color/white"
                                        android:textSize="14sp"
                                        android:textStyle="bold" />
                                </RelativeLayout>
                            </androidx.cardview.widget.CardView>

                        </LinearLayout>
                    </HorizontalScrollView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
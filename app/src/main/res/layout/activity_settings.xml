<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_surface"
    tools:context=".SettingsActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/md_theme_surface"
        app:elevation="1dp">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:contentInsetStart="0dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_back"
                    app:tint="@color/primary"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="8dp"
                    android:contentDescription="Back" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settings"
                    android:textColor="@color/primary"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_toEndOf="@id/btn_back"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="8dp" />
            </RelativeLayout>
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="40dp">

            <!-- Profile Overview Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/md_theme_surface_container"
                android:layout_marginBottom="32dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/md_theme_surface_dim">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/profile_image_container"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        app:cardCornerRadius="36dp"
                        app:cardElevation="0dp"
                        android:layout_centerVertical="true">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/profile_habibie"
                            android:contentDescription="Profile Picture" />
                    </com.google.android.material.card.MaterialCardView>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toEndOf="@id/profile_image_container"
                        android:layout_toStartOf="@id/btn_edit_profile"
                        android:layout_marginStart="16dp"
                        android:layout_centerVertical="true">
                        <TextView
                            android:id="@+id/tv_profile_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="User Name"
                            android:textColor="@color/primary"
                            android:textStyle="bold"
                            android:textSize="22sp" />
                        <TextView
                            android:id="@+id/tv_profile_email"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="user@email.com"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="14sp" />
                    </LinearLayout>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_edit_profile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Edit"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:textColor="@color/primary"
                        app:strokeColor="@color/md_theme_surface_dim"
                        app:cornerRadius="24dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:minWidth="0dp"
                        android:paddingHorizontal="20dp" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Account & Security Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCOUNT &amp; SECURITY"
                android:textColor="@color/md_theme_surface_dim"
                android:textStyle="bold"
                android:textSize="11sp"
                android:letterSpacing="0.05"
                android:layout_marginStart="12dp"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/md_theme_surface_container"
                android:layout_marginBottom="24dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/md_theme_surface_dim">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Phone Number -->
                    <RelativeLayout
                        android:id="@+id/item_account_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icon_phone_container"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/md_theme_surface">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_smartphone"
                                app:tint="@color/primary"
                                android:contentDescription="Phone Icon" />
                        </com.google.android.material.card.MaterialCardView>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icon_phone_container"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phone Number"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:textSize="16sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+62 812 3456 7890"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="13sp" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/md_theme_surface_dim"
                            android:contentDescription="Forward" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/md_theme_surface_dim" android:layout_marginStart="76dp" />

                    <!-- KTM Verification -->
                    <RelativeLayout
                        android:id="@+id/item_ktm_verification"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icon_ktm_container"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/md_theme_surface">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_id_card"
                                app:tint="@color/primary"
                                android:contentDescription="ID Card Icon" />
                        </com.google.android.material.card.MaterialCardView>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icon_ktm_container"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="KTM Verification"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:textSize="16sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Verified"
                                android:textColor="@color/secondary"
                                android:textSize="13sp" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/md_theme_surface_dim"
                            android:contentDescription="Forward" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/md_theme_surface_dim" android:layout_marginStart="76dp" />

                    <!-- Security -->
                    <RelativeLayout
                        android:id="@+id/item_security"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icon_security_container"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/md_theme_surface">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_shield"
                                app:tint="@color/primary"
                                android:contentDescription="Security Icon" />
                        </com.google.android.material.card.MaterialCardView>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icon_security_container"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Security"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:textSize="16sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Password, 2-Factor Authentication"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="13sp" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/md_theme_surface_dim"
                            android:contentDescription="Forward" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Communication Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMMUNICATION"
                android:textColor="@color/md_theme_surface_dim"
                android:textStyle="bold"
                android:textSize="11sp"
                android:letterSpacing="0.05"
                android:layout_marginStart="12dp"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/md_theme_surface_container"
                android:layout_marginBottom="24dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/md_theme_surface_dim">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Notifications -->
                    <RelativeLayout
                        android:id="@+id/item_notifications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icon_notif_container"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/md_theme_surface">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_bell"
                                app:tint="@color/primary"
                                android:contentDescription="Notifications Icon" />
                        </com.google.android.material.card.MaterialCardView>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icon_notif_container"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Notifications"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:textSize="16sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Push, Email, SMS"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="13sp" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/md_theme_surface_dim"
                            android:contentDescription="Forward" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/md_theme_surface_dim" android:layout_marginStart="76dp" />

                    <!-- Chat Options -->
                    <RelativeLayout
                        android:id="@+id/item_chat_options"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icon_chat_container"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/md_theme_surface">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_chat_bubble"
                                app:tint="@color/primary"
                                android:contentDescription="Chat Icon" />
                        </com.google.android.material.card.MaterialCardView>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icon_chat_container"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chat Options"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:textSize="16sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Message privacy, Read receipts"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="13sp" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/md_theme_surface_dim"
                            android:contentDescription="Forward" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Preferences Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PREFERENCES"
                android:textColor="@color/md_theme_surface_dim"
                android:textStyle="bold"
                android:textSize="11sp"
                android:letterSpacing="0.05"
                android:layout_marginStart="12dp"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/md_theme_surface_container"
                android:layout_marginBottom="24dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/md_theme_surface_dim">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Display -->
                    <RelativeLayout
                        android:id="@+id/item_display"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icon_display_container"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/md_theme_surface">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_devices"
                                app:tint="@color/primary"
                                android:contentDescription="Display Icon" />
                        </com.google.android.material.card.MaterialCardView>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icon_display_container"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Display"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:textSize="16sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Light Mode"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="13sp" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/md_theme_surface_dim"
                            android:contentDescription="Forward" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/md_theme_surface_dim" android:layout_marginStart="76dp" />

                    <!-- Language -->
                    <RelativeLayout
                        android:id="@+id/item_language"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icon_lang_container"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/md_theme_surface">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_globe"
                                app:tint="@color/primary"
                                android:contentDescription="Language Icon" />
                        </com.google.android.material.card.MaterialCardView>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icon_lang_container"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Language"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:textSize="16sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="English"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="13sp" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/md_theme_surface_dim"
                            android:contentDescription="Forward" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Others Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OTHERS"
                android:textColor="@color/md_theme_surface_dim"
                android:textStyle="bold"
                android:textSize="11sp"
                android:letterSpacing="0.05"
                android:layout_marginStart="12dp"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/md_theme_surface_container"
                app:strokeWidth="1dp"
                app:strokeColor="@color/md_theme_surface_dim">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Support & Help -->
                    <RelativeLayout
                        android:id="@+id/item_support"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icon_support_container"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/md_theme_surface">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_help_circle"
                                app:tint="@color/primary"
                                android:contentDescription="Support Icon" />
                        </com.google.android.material.card.MaterialCardView>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icon_support_container"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Support &amp; Help"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:textSize="16sp" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/md_theme_surface_dim"
                            android:contentDescription="Forward" />
                    </RelativeLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/md_theme_surface_dim" android:layout_marginStart="76dp" />

                    <!-- About App -->
                    <RelativeLayout
                        android:id="@+id/item_about"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:background="?attr/selectableItemBackground">
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/icon_about_container"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            app:cardCornerRadius="22dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/md_theme_surface">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="12dp"
                                android:src="@drawable/ic_logo_nongki"
                                app:tint="@color/primary"
                                android:contentDescription="About Icon" />
                        </com.google.android.material.card.MaterialCardView>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/icon_about_container"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical"
                            android:layout_centerVertical="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="About Application"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:textSize="16sp" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Version 1.0.5"
                                android:textColor="@color/on_surface_variant"
                                android:textSize="13sp" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/md_theme_surface_dim"
                            android:contentDescription="Forward" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Logout Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/md_theme_surface_container"
                app:strokeWidth="1dp"
                app:strokeColor="@color/md_theme_surface_dim">
                <RelativeLayout
                    android:id="@+id/btn_logout_item"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground">
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/icon_logout_container"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/error_container">
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp"
                            android:src="@drawable/ic_arrow_forward"
                            app:tint="@color/error"
                            android:contentDescription="Logout Icon" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/icon_logout_container"
                        android:layout_marginStart="16dp"
                        android:layout_centerVertical="true"
                        android:text="Logout"
                        android:textColor="@color/error"
                        android:textStyle="bold"
                        android:textSize="16sp" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Top Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@color/primary"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_back"
            android:contentDescription="Kembali"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginStart="8dp">
                <androidx.cardview.widget.CardView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="BIB"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:textSize="16sp"
                        tools:ignore="SmallSp" />
                </androidx.cardview.widget.CardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bib_label"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_label_dark"
                    android:paddingHorizontal="4dp"
                    android:layout_marginTop="-4dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Search Bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/search_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/header_layout">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_search_bar"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/black"
                android:contentDescription="Cari" />
            <EditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="@string/search_hint"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textSize="14sp"
                android:importantForAutofill="no"
                android:inputType="text" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Filter Labels -->
    <LinearLayout
        android:id="@+id/filter_labels"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/search_container">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/type_place"
            android:textStyle="bold"
            android:textColor="@color/text_dark"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bib_year"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_marginEnd="60dp"/>
    </LinearLayout>

    <!-- Filter Chips -->
    <HorizontalScrollView
        android:id="@+id/filter_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:clipToPadding="false"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/filter_labels">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_cafe"
                app:chipBackgroundColor="#114C5F"
                android:textColor="@color/white"
                app:chipCornerRadius="8dp"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_perpus"
                app:chipBackgroundColor="#EEE"
                android:textColor="@color/text_dark"
                app:chipCornerRadius="8dp"
                android:layout_marginEnd="8dp"/>

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_taman"
                app:chipBackgroundColor="#EEE"
                android:textColor="@color/text_dark"
                app:chipCornerRadius="8dp"
                android:layout_marginEnd="16dp"/>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#DDD"
                android:layout_marginEnd="16dp"/>

            <com.google.android.material.chip.Chip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/filter_univ"
                app:chipBackgroundColor="#EEE"
                android:textColor="@color/text_dark"
                app:chipCornerRadius="8dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Map Area Container -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/map_area"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="72dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filter_scroll">

        <!-- Background Map -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@android:drawable/ic_dialog_map"
            android:contentDescription="Peta"
            app:tint="#E0E0E0" />

        <!-- Floating Labels on Map -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_label_dark"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:gravity="center">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_location_pin"
                android:contentDescription="Pin Lokasi"
                app:tint="@color/primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bib_spots"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="56dp"
            android:background="@drawable/bg_map_overlay"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:gravity="center">
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_profile"
                android:contentDescription="Avatar Teman"
                app:tint="@color/primary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/teman_nongki"
                android:textColor="@color/text_dark"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Draggable Bottom Sheet -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottom_sheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bottom_sheet"
            android:elevation="16dp"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
            app:behavior_peekHeight="380dp"
            app:behavior_hideable="false">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                android:paddingBottom="8dp">

                <!-- Handle bar (Indikator Drag) -->
                <View
                    android:id="@+id/handle"
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_marginTop="12dp"
                    android:background="#DDD"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Scrollable List Area -->
                <androidx.core.widget.NestedScrollView
                    android:id="@+id/scroll_view"
                    android:layout_width="match_parent"
                    android:layout_height="210dp"
                    android:layout_marginTop="8dp"
                    app:layout_constraintTop_toBottomOf="@id/handle"
                    app:layout_constraintBottom_toTopOf="@id/btn_container">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="20dp"
                        android:paddingTop="8dp">

                        <!-- Item 1: Cafe Sudut -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">
                            <androidx.cardview.widget.CardView
                                android:id="@+id/img_1"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                app:cardCornerRadius="30dp">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_home"
                                    android:padding="12dp"
                                    android:background="#F0F0F0"
                                    android:contentDescription="Cafe Sudut"
                                    app:tint="@color/primary" />
                            </androidx.cardview.widget.CardView>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/img_1"
                                android:layout_toStartOf="@+id/avatar_1"
                                android:layout_marginStart="16dp"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/cafe_sudut"
                                    android:textStyle="bold"
                                    android:textSize="16sp"
                                    android:textColor="@color/text_dark"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/cafe_sudut_desc"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_grey"/>
                            </LinearLayout>
                            <ImageView
                                android:id="@+id/avatar_1"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_profile"
                                android:contentDescription="Avatar"
                                app:tint="@color/primary" />
                        </RelativeLayout>

                        <!-- Item 2: Perpus Pusat -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">
                            <androidx.cardview.widget.CardView
                                android:id="@+id/img_2"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                app:cardCornerRadius="30dp">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_map"
                                    android:padding="12dp"
                                    android:background="#F0F0F0"
                                    android:contentDescription="Perpus Pusat"
                                    app:tint="@color/primary" />
                            </androidx.cardview.widget.CardView>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/img_2"
                                android:layout_toStartOf="@+id/avatar_2"
                                android:layout_marginStart="16dp"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/perpus_pusat"
                                    android:textStyle="bold"
                                    android:textSize="16sp"
                                    android:textColor="@color/text_dark"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/perpus_pusat_desc"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_grey"/>
                            </LinearLayout>
                            <ImageView
                                android:id="@+id/avatar_2"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_profile"
                                android:contentDescription="Avatar"
                                app:tint="@color/primary" />
                        </RelativeLayout>

                        <!-- Item 3: Taman Kota -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp">
                            <androidx.cardview.widget.CardView
                                android:id="@+id/img_3"
                                android:layout_width="60dp"
                                android:layout_height="60dp"
                                app:cardCornerRadius="30dp">
                                <ImageView
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_acara"
                                    android:padding="12dp"
                                    android:background="#F0F0F0"
                                    android:contentDescription="Taman Kota"
                                    app:tint="@color/primary" />
                            </androidx.cardview.widget.CardView>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/img_3"
                                android:layout_toStartOf="@+id/avatar_3"
                                android:layout_marginStart="16dp"
                                android:layout_centerVertical="true"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/Taman_Literasi"
                                    android:textStyle="bold"
                                    android:textSize="16sp"
                                    android:textColor="@color/text_dark"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/Taman_Literasi_desc"
                                    android:textSize="12sp"
                                    android:textColor="@color/text_grey"/>
                            </LinearLayout>
                            <ImageView
                                android:id="@+id/avatar_3"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_profile"
                                android:contentDescription="Avatar"
                                app:tint="@color/primary" />
                        </RelativeLayout>
                    </LinearLayout>
                </androidx.core.widget.NestedScrollView>

                <!-- Sticky Bottom Buttons -->
                <LinearLayout
                    android:id="@+id/btn_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/scroll_view">
                    <Button
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:text="@string/btn_new_location"
                        android:textAllCaps="false"
                        android:textColor="@color/primary"
                        android:backgroundTint="@color/white"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="@color/primary"
                        app:strokeWidth="2dp"
                        app:cornerRadius="27dp"
                        android:layout_marginEnd="8dp"/>
                    <Button
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_weight="1"
                        android:text="@string/btn_make_appointment"
                        android:textAllCaps="false"
                        android:backgroundTint="#114C5F"
                        android:textColor="@color/white"
                        app:cornerRadius="27dp"
                        style="@style/Widget.MaterialComponents.Button"/>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
